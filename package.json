{
  "name": "razorpayx-sdk",
  "version": "0.1.1",
  "description": "Unofficial Node.js SDK for the RazorpayX API (Contacts, Fund Accounts, Payouts, Payout Links, Transactions, Account Validation, Balances) written in TypeScript.",
  "keywords": [
    "razorpayx",
    "razorpay",
    "payouts",
    "banking",
    "payments",
    "sdk"
  ],
  "license": "MIT",
  "author": "Himanshu Singh",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
